# ============================================================
#  WhatsApp Agent System — Environment Variables
#  Copy this file to .env and fill in your values.
# ============================================================

# ─── Gemini API ─────────────────────────────────────────────
# Get your free key at https://aistudio.google.com/
GEMINI_API_KEY=AIzaSyCN_Cbrcz6euADJJSTNSX_lEC2IVid-4sg

# ─── SMTP / Email ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=adhilnuckz@gmail.com
SMTP_PASS=nqbxrkaeoutctlel
EMAIL_FROM="WhatsApp Agent <your_email@gmail.com>"

# ─── Authorized WhatsApp Numbers ────────────────────────────
# Comma-separated, include country code without '+', e.g. 15551234567
ADMIN_NUMBERS=15551234567,15557654321

# ─── Agent Chat Trigger ─────────────────────────────────────
# Name of the WhatsApp group/contact that the bot monitors, OR a keyword prefix
AGENT_CHAT_NAME=Agent
COMMAND_PREFIX=!

# ─── Dashboard ──────────────────────────────────────────────
DASHBOARD_PORT=5555
DASHBOARD_SECRET=change_this_to_a_strong_secret

# ─── Browser (Puppeteer) ─────────────────────────────────────
# Windows local dev (Edge, visible window):
#   HEADLESS=false
#   BROWSER_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
#
# Linux server (Chrome, headless):
#   HEADLESS=true
#   BROWSER_PATH=/usr/bin/google-chrome
HEADLESS=true
BROWSER_PATH=/usr/bin/google-chrome

# ─── Gmail API (OAuth2) ──────────────────────────────────────
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
GMAIL_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxx

# ─── Weather API (optional — OpenWeatherMap free tier) ───────
WEATHER_API_KEY=your_openweather_api_key_here
WEATHER_DEFAULT_CITY=New York

# ─── CoinGecko (no key needed, but rate-limited) ────────────
CRYPTO_DEFAULT=bitcoin,ethereum,solana

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ─── Nmap / Security ────────────────────────────────────────
# Whitelist of IPs/subnets that nmap is ALLOWED to scan
NMAP_ALLOWED_TARGETS=127.0.0.1,192.168.1.0/24

# ─── Shell Command Whitelist ─────────────────────────────────
# Additional commands beyond the built-in list (comma-separated)
EXTRA_ALLOWED_CMDS=
